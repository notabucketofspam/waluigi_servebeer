{
  "include": ["./src/**/*"],
  "compileOnSave": true,
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "../html/dist",
    "tsBuildInfoFile": "../html/dist/tsconfig.tsbuildinfo",

    "module": "esnext",
    "target": "esnext",
    "types": [],
    "lib": ["DOM", "ESNext"],

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "paths": {},

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true
  },
  "references": []
}
